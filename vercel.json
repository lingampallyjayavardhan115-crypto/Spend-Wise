{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/expenses/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/budgets/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
